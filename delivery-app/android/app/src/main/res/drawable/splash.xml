<?xml version="1.0" encoding="utf-8"?>
<!-- Splash screen shown while the TWA loads -->
<!-- Replace with your actual logo/icon once you have it -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background fill -->
    <item>
        <color android:color="#D85A30" />
    </item>

    <!-- Centred logo placeholder -->
    <!-- Swap this for @drawable/ic_logo once you have a proper logo file -->
    <item
        android:gravity="center"
        android:width="120dp"
        android:height="120dp">
        <shape android:shape="oval">
            <solid android:color="#fff" />
        </shape>
    </item>

</layer-list>
