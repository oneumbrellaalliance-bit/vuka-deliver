# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MTN Mobile Money (get from developers.mtn.com)
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your-subscription-key
MTN_MOMO_API_USER=your-api-user-uuid
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_TARGET_ENV=sandbox   # change to production when live

# Airtel Money Rwanda (get from developers.airtel.africa)
AIRTEL_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_CLIENT_ID=your-client-id
AIRTEL_CLIENT_SECRET=your-client-secret
AIRTEL_ENV=staging   # change to production when live

# Africa's Talking (SMS + WhatsApp notifications)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-username
AT_SENDER_ID=VukaDeliver

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# App
NEXT_PUBLIC_APP_NAME=Vuka Deliver
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
